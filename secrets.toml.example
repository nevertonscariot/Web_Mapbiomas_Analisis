# Exemplo de Secrets do Streamlit.
# No Streamlit Community Cloud: App → Settings → Secrets → cole o conteúdo abaixo.
# Localmente: salve como  .streamlit/secrets.toml  (NÃO faça commit deste arquivo).
#
# A chave é OPCIONAL — o app funciona 100% sem ela (análise local).
# Se definida, todos os usuários recebem a análise por IA sem digitar nada.

GOOGLE_GEMINI_API_KEY = "cole_sua_chave_gemini_aqui"
